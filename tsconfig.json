{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@shared/*": ["./amplify/functions/shared/*"]
    }
  },
  "include": ["amplify/**/*.ts"],
  "exclude": ["node_modules", "client"]
}
