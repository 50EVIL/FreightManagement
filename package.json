{
  "name": "freight-management",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "amplify:sandbox": "npx ampx sandbox",
    "amplify:deploy": "npx ampx pipeline-deploy",
    "amplify:generate": "npx ampx generate outputs --app-id $(cat .amplify-app-id) --branch main"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.6.0",
    "@aws-amplify/backend-cli": "^1.4.0",
    "aws-cdk-lib": "^2.161.0",
    "constructs": "^10.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
